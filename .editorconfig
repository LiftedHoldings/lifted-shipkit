# EditorConfig — https://editorconfig.org
# Top-most EditorConfig file for ShipKit.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.{kt,kts}]
indent_size = 4
ktlint_standard_no-wildcard-imports = enabled

[*.{js,mjs,cjs,ts,json,css,html,yml,yaml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.{gradle,gradle.kts}]
indent_size = 4

[Makefile]
indent_style = tab

[Dockerfile]
indent_size = 2
