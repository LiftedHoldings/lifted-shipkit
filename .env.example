# ShipKit — example environment configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
#
# NEVER commit `.env` — it is git-ignored. Every value below is a non-secret
# PLACEHOLDER. Replace placeholders with real credentials only in your local
# `.env` or your deployment environment. ShipKit reads all config from the
# environment via ShipKitConfig; there are no hardcoded credentials.
# ===========================================================================

# --- Server -----------------------------------------------------------------
# HTTP port the Javalin server binds to.
SHIPKIT_PORT=8080
# Public base URL of this deployment (3-D Secure return URLs, absolute links).
# No trailing slash.
SHIPKIT_BASE_URL=http://localhost:8080
# Comma-separated allowed CORS origins for the widget, or `*` in dev.
SHIPKIT_CORS_ORIGINS=*

# --- EasyPost (shipping) ----------------------------------------------------
# Your EasyPost API key. Get one at https://www.easypost.com. Test keys start
# with EZTK..., production keys with EZAK... Placeholder shown below.
EASYPOST_API_KEY=EZTK_your_easypost_test_key_here
# Shared secret used to verify inbound EasyPost tracking webhooks (HMAC-SHA256).
EASYPOST_WEBHOOK_SECRET=replace_with_a_random_webhook_secret

# --- Lifted Payments — 3-D Secure card payments -----------------------------
# ShipKit's payment layer is "Secured by Lifted Payments 3-D Secure".
# 3-D Secure is ALWAYS enforced — there is no flag to disable it.
# Apply for a 3-D Secure merchant account at https://liftedholdings.com/payments
# Gateway host (processing: sale/auth, transaction verification).
LIFTED_PAYMENTS_API_BASE=https://gateway.maverickpayments.com
# Dashboard host (hosted 3-D Secure form / vault).
LIFTED_PAYMENTS_DASHBOARD_BASE=https://dashboard.maverickpayments.com
# Bearer token issued with your merchant account.
LIFTED_PAYMENTS_BEARER=lp_test_your_lifted_payments_bearer_token_here
# Terminal id (required on every money call).
LIFTED_PAYMENTS_TERMINAL_ID=000000
# DBA id.
LIFTED_PAYMENTS_DBA_ID=000000

# --- Label store ------------------------------------------------------------
# Where purchased-label records are persisted: memory | postgres
# `memory` needs no database and is the zero-config default.
SHIPKIT_STORE=memory
# Only used when SHIPKIT_STORE=postgres. TLS is required — keep sslmode=require;
# never use a cleartext connection.
SHIPKIT_DATABASE_URL=jdbc:postgresql://localhost:5432/shipkit?sslmode=require
SHIPKIT_DB_USER=shipkit
SHIPKIT_DB_PASSWORD=replace_with_your_db_password

# --- Twilio SMS (optional module, OFF by default) ---------------------------
# Optional phone verification for the purchase-history and admin surfaces.
SHIPKIT_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_with_your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Admin ------------------------------------------------------------------
# Comma-separated phone numbers allowed to reach /api/admin.
SHIPKIT_ADMIN_PHONES=
