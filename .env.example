# ShipKit — example environment configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
#
# NEVER commit `.env` — it is git-ignored. Every value below is a non-secret
# PLACEHOLDER. Replace placeholders with real credentials only in your local
# `.env` or your deployment environment. ShipKit reads all config from the
# environment via ShipKitConfig; there are no hardcoded credentials.
# ===========================================================================

# --- Server -----------------------------------------------------------------
# HTTP port the Javalin server binds to.
SHIPKIT_PORT=8080
# Public base URL of this deployment (3-D Secure return URLs, absolute links).
# No trailing slash.
SHIPKIT_BASE_URL=http://localhost:8080
# Comma-separated allowed CORS origins for the widget, or `*` in dev.
SHIPKIT_CORS_ORIGINS=*

# --- EasyPost (shipping) ----------------------------------------------------
# Your EasyPost API key. Get one at https://www.easypost.com. Test keys start
# with EZTK..., production keys with EZAK... Placeholder shown below.
EASYPOST_API_KEY=EZTK_your_easypost_test_key_here
# Shared secret used to verify inbound EasyPost tracking webhooks (HMAC-SHA256).
EASYPOST_WEBHOOK_SECRET=replace_with_a_random_webhook_secret

# --- Lifted Payments — 3-D Secure card payments -----------------------------
# ShipKit's payment layer is "Secured by Lifted Payments 3-D Secure".
# 3-D Secure is ALWAYS enforced — there is no flag to disable it.
# Apply for a 3-D Secure merchant account at https://liftedholdings.com/payments
#
# Environment: live | sandbox. Selects the default gateway/dashboard bases
# (live: gateway.maverickpayments.com / dashboard.maverickpayments.com;
#  sandbox: sandbox-gateway.maverickpayments.com / sandbox-dashboard.…). An
# explicit *_API_BASE / *_DASHBOARD_BASE below still overrides these.
LIFTED_PAYMENTS_ENV=live
# Gateway host (processing: /payment/sale, /payment/{id}/capture|refund, GET
# /payment/{id}). Leave blank to derive from LIFTED_PAYMENTS_ENV.
LIFTED_PAYMENTS_API_BASE=https://gateway.maverickpayments.com
# Dashboard host (Hosted Fields token minting + hosted payment page / vault).
LIFTED_PAYMENTS_DASHBOARD_BASE=https://dashboard.maverickpayments.com
# Browser card-entry model: hosted_fields (primary, PCI-reducing, tokenize
# in-browser then charge server-side) | hosted_form (redirect to a Maverick
# hosted page).
LIFTED_PAYMENTS_CARD_ENTRY=hosted_fields
# Hosted-form creation path on the dashboard host. UNVERIFIED — confirm the exact
# path in developers.maverickpayments.com before enabling hosted_form. Ignored by
# the hosted_fields flow.
LIFTED_PAYMENTS_HOSTED_FORM_PATH=/api/gateway/hosted-form
# Bearer token issued with your merchant account.
LIFTED_PAYMENTS_BEARER=lp_test_your_lifted_payments_bearer_token_here
# Terminal id (required on every money call).
LIFTED_PAYMENTS_TERMINAL_ID=000000
# DBA id.
LIFTED_PAYMENTS_DBA_ID=000000

# --- Adoption tier + buyer surcharge (the three-tier pricing model) ---------
# Which tier this deployment runs under (informational; gates no endpoint):
#   selfhost — DIY, free MIT; bring your own payments + your own EasyPost.
#   merchant — a Lifted 3-D Secure merchant account (3.75% + $0.15 / txn + $25/mo).
#   managed  — fully managed on Lifted's rails; Lifted earns via shipping markup.
SHIPKIT_TIER=selfhost
# Tier-2 only: pass the 3.75% + $0.15 merchant-account fee to the buyer at
# checkout (added to the charged amount). Off by default — surcharging is a
# deliberate, jurisdiction-aware choice.
SHIPKIT_SURCHARGE_ENABLED=false
# Account-gated FRICTIONLESS / card-on-file capability (SPEC_R3 §5). When ON, the
# server may charge with 3-D Secure OFF (`3ds:false`) and save/charge cards on file
# (Maverick customer vault → one-tap repeat checkout). This is a SERVER-SIDE, tier-
# derived switch — NEVER a client/widget toggle.
#   OFF by default = forced 3-D Secure (the fraud/chargeback protection is the pitch).
#   Available ONLY on a Lifted merchant/managed account (SHIPKIT_TIER=merchant|managed)
#   or an enterprise custom-dev account (support@liftedholdings.com).
# Forced 3-D Secure is the ONLY mode for self-host / bring-your-own-payments:
# setting this to `true` while SHIPKIT_TIER=selfhost is REFUSED and the server will
# fail to start (self-host cannot disable 3-D Secure).
SHIPKIT_FRICTIONLESS_ENABLED=false

# --- Label store ------------------------------------------------------------
# Where purchased-label records are persisted: memory | postgres
# `memory` needs no database and is the zero-config default.
SHIPKIT_STORE=memory
# Only used when SHIPKIT_STORE=postgres. TLS is required — keep sslmode=require;
# never use a cleartext connection.
SHIPKIT_DATABASE_URL=jdbc:postgresql://localhost:5432/shipkit?sslmode=require
SHIPKIT_DB_USER=shipkit
SHIPKIT_DB_PASSWORD=replace_with_your_db_password

# --- Twilio SMS (optional module, OFF by default) ---------------------------
# Optional phone verification for the purchase-history and admin surfaces.
SHIPKIT_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_with_your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Admin ------------------------------------------------------------------
# Comma-separated phone numbers allowed to reach /api/admin.
SHIPKIT_ADMIN_PHONES=

# --- Managed-deployment hooks (optional, BOTH OFF by default) ---------------
# For operators hosting ShipKit instances on behalf of others (a control plane
# managing many deployments). Ordinary self-host setups leave all three unset.
#
# Bearer token that lets your platform update the shipping markup remotely:
#   POST /api/config/markup  with  Authorization: Bearer <token>
# accepting {markup_pct, fixed_fee} (percent + dollars) or the native
# {percentage_markup, fixed_fee_cents} body. Compared in constant time; scoped
# to that single endpoint. UNSET (default) = the bearer path is disabled —
# fail closed; only sk_ keys can write markup. Use a long random value — e.g.
# `openssl rand -base64 32` — never a word or a reused password.
SHIPKIT_MANAGED_CONFIG_TOKEN=
# Usage-event webhook: every successful label purchase is POSTed to this URL as
# a `label.purchased` v1 envelope (money in integer cents; the tenant is the
# caller's non-secret key prefix — never a full key, never card data).
# Fire-and-forget with one retry: it can never block or fail a purchase.
# UNSET (default) = no events are sent.
SHIPKIT_EVENTS_WEBHOOK_URL=
# Optional shared secret sent as `Authorization: Bearer <token>` on each event.
SHIPKIT_EVENTS_WEBHOOK_TOKEN=
